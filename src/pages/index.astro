---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Shingai Thornton">
  <div class="space-y-6">
    <div class="space-y-3">
      <h1 class="text-3xl font-semibold text-stone-900" style="font-family: 'Source Serif 4', Georgia, serif;">Systems Scientist</h1>
      <p class="text-stone-600 leading-relaxed max-w-md">
        I study complex systems using network science, formal modeling, and systems theory. I write about what I learn.
      </p>
    </div>
    <div class="flex gap-4 pt-2">
      <a href="/archive" class="text-sm text-stone-500 hover:text-stone-900 no-underline">Read the archive &rarr;</a>
    </div>
  </div>
</BaseLayout>
