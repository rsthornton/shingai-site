---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Shingai Thornton">
  <article class="prose">
    <h1 class="text-3xl font-semibold text-stone-900 mb-8" style="font-family: 'Source Serif 4', Georgia, serif;">About</h1>
    <div class="text-stone-700 space-y-6">
      <p>
        I'm a systems scientist studying how complex adaptive systems emerge, evolve, and interact.
        My work bridges network science, cryptoeconomics, and political economy.
      </p>
      <p>
        I hold an MS in Systems Science from Portland State University, where I studied interstate
        commerce networks and economic complexity using formal methods from systems theory.
      </p>
    </div>
    <div class="mt-12 pt-6 border-t border-stone-200">
      <div class="flex gap-6 text-sm">
        <a href="https://twitter.com/shingai" class="text-stone-500 hover:text-stone-900">Twitter</a>
        <a href="https://github.com/rsthornton" class="text-stone-500 hover:text-stone-900">GitHub</a>
      </div>
    </div>
  </article>
</BaseLayout>
