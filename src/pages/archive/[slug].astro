---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('archive');
  return posts.map((post) => ({
    params: { slug: post.data.permalink },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.data.title} | Shingai Thornton`}>
  <article class="prose">
    <header class="mb-10">
      <a href="/archive" class="text-xs hover:text-stone-700 no-underline mb-4 inline-block uppercase tracking-widest" style="color: #a3856a;">&larr; Archive</a>
      <h1 class="text-3xl font-semibold text-stone-900 mb-3 mt-2" style="font-family: 'Source Serif 4', Georgia, serif;">{post.data.title}</h1>
      <time class="text-xs text-stone-400 tracking-wide">{formattedDate}</time>
    </header>
    <div class="text-stone-700">
      <Content />
    </div>
  </article>
  <div class="mt-16 pt-6 border-t" style="border-color: #d4c4b0;">
    <a href="/archive" class="text-xs hover:text-stone-700 no-underline uppercase tracking-widest" style="color: #a3856a;">&larr; Archive</a>
  </div>
</BaseLayout>
